#!/usr/bin/env bash
set -Eeuo pipefail

##########################################################################
# Mirror a Git repository from many remotes.                           #
#                                                                    #
# Can create a local mirror/archive, or mirror to one or more remotes,   #
# i.e. github to gitlab, codeberg to github and gitlab, etc.            #
#                                                                    #
# The script should work with any Git-compliant forge. It can clone     #
# public and private repositories over HTTPS or SSH. For SSH cloning,   #
# the script uses the host's SSH agent by default.                     #
#                                                                    #
# Run with -h or --help to see usage and options.                      #
##########################################################################

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"

## Source lib scripts
source "${LIB_DIR}/logging.sh"
source "${LIB_DIR}/core.sh"
source "${LIB_DIR}/auth.sh"
source "${LIB_DIR}/git.sh"
source "${LIB_DIR}/mirror.sh"
source "${LIB_DIR}/sync.sh"
source "${LIB_DIR}/replicate.sh"

## Set defaults
MODE="mirror"
SOURCE_URL=""
TARGET_URL=""
LOCAL_ROOT="./repos"
DRY_RUN="0"
DEBUG="0"
VERBOSE="0"
DESTS=()

## Env defaults; CLI flags override these values.
AUTH_MODE="${AUTH_MODE:-}"
SSH_KEY_FILE="${SSH_KEY_FILE:-}"
SSH_KEY_ENV="${SSH_KEY_ENV:-}"
HTTPS_TOKEN="${HTTPS_TOKEN:-}"
HTTPS_TOKEN_ENV="${HTTPS_TOKEN_ENV:-}"

if [[ -n "${MIRROR_LOCAL_ROOT:-}" ]]; then
  LOCAL_ROOT="${MIRROR_LOCAL_ROOT}"
fi
if [[ -n "${MIRROR_DRY_RUN:-}" ]]; then
  DRY_RUN="${MIRROR_DRY_RUN}"
fi
if [[ -n "${MIRROR_DEBUG:-}" ]]; then
  DEBUG="${MIRROR_DEBUG}"
fi
if [[ -n "${MIRROR_VERBOSE:-}" ]]; then
  VERBOSE="${MIRROR_VERBOSE}"
fi

function usage() {
  cat <<'EOF'
Usage:
  mirror-git-repo <command> <source-url> [options]

Commands:
  mirror     Create or update a local bare mirror.
  sync       Mirror locally, then push to one or more destination remotes.
  replicate  Mirror one source directly to one destination remote.

Options:
  --local-root <dir>        Local mirror root directory. Default: ./repos
  --dest <name=url>         Destination remote mapping. Repeatable. Used by sync.
  --dest <url>              Destination URL with an auto-generated remote name.
  --dry-run                 Print commands without executing them.
  --debug                   Enable debug logging.
  --verbose                 Enable verbose logging.
  --auth-mode <ssh|https>   Force auth mode instead of auto-detect from URL.
  --ssh-key-file <path>     Use this SSH private key file for SSH auth.
  --ssh-key-env <ENVVAR>    Use the value of this environment variable as an SSH private key.
  --https-token <token>     Use this HTTPS bearer token for HTTPS auth.
  --https-token-env <ENVVAR>
                            Use the value of this environment variable as a bearer token for HTTPS auth.
  -h, --help                Show this help message.

Auth notes:
  SSH auth defaults to the host SSH client and agent unless --ssh-key-file or --ssh-key-env is set.
  If --ssh-key-env is used, the named environment variable must contain the full private key text.
  If --https-token-env is used, the named environment variable must contain the token value.
  HTTPS token auth is used for https:// source URLs.

Examples:
  mirror-git-repo mirror git@github.com:org/repo.git
  mirror-git-repo mirror [https://github.com/org/repo.git](https://github.com/org/repo.git) --local-root /tmp/repos
  mirror-git-repo sync git@github.com:org/repo.git --dest gitlab=git@gitlab.com:org/repo.git
  mirror-git-repo sync git@github.com:org/repo.git --dest git@gitlab.com:org/repo.git
  mirror-git-repo replicate git@github.com:org/repo.git git@gitlab.com:org/repo.git
  mirror-git-repo mirror git@github.com:org/repo.git --ssh-key-file /run/secrets/id_ed25519
  mirror-git-repo mirror git@github.com:org/repo.git --ssh-key-env MIRROR_SSH_KEY
  mirror-git-repo mirror [https://github.com/org/repo.git](https://github.com/org/repo.git) --https-token ghp_xxx
  mirror-git-repo mirror [https://github.com/org/repo.git](https://github.com/org/repo.git) --https-token-env GIT_TOKEN
EOF
}

function require_arg() {
  local flag="$1"
  local value="${2:-}"

  if [[ -z "$value" || "$value" == --* ]]; then
    error "missing value for $flag"
    exit 2
  fi
}

function parse_replication_target() {
  if [[ $# -gt 0 && "${1:-}" != --* ]]; then
    TARGET_URL="$1"
    shift
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dest)
        require_arg "--dest" "${2:-}"
        DESTS+=("$2")
        shift 2
        ;;
      --local-root)
        require_arg "--local-root" "${2:-}"
        LOCAL_ROOT="$2"
        shift 2
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      --debug)
        DEBUG=1
        shift
        ;;
      --verbose)
        VERBOSE=1
        shift
        ;;
      --auth-mode)
        require_arg "--auth-mode" "${2:-}"
        AUTH_MODE="$2"
        shift 2
        ;;
      --ssh-key-file)
        require_arg "--ssh-key-file" "${2:-}"
        SSH_KEY_FILE="$2"
        shift 2
        ;;
      --ssh-key-env)
        require_arg "--ssh-key-env" "${2:-}"
        SSH_KEY_ENV="$2"
        shift 2
        ;;
      --https-token)
        require_arg "--https-token" "${2:-}"
        HTTPS_TOKEN="$2"
        shift 2
        ;;
      --https-token-env)
        require_arg "--https-token-env" "${2:-}"
        HTTPS_TOKEN_ENV="$2"
        shift 2
        ;;
      *)
        error "unknown: $1"
        exit 2
        ;;
    esac
  done

  if [[ -z "$TARGET_URL" && ${#DESTS[@]} -gt 0 ]]; then
    TARGET_URL="$(resolve_target_url "${DESTS[0]}")"
  fi

  if [[ -z "$TARGET_URL" ]]; then
    error "replicate requires a destination URL (positional arg or --dest)"
    exit 2
  fi
}

function parse_args() {
  for arg in "$@"; do
    case "$arg" in
      -h | --help)
        usage
        exit 0
        ;;
    esac
  done

  [[ $# -gt 0 ]] || {
    usage
    exit 1
  }

  case "$1" in
    mirror | sync | replicate)
      MODE="$1"
      shift
      ;;
  esac

  [[ $# -gt 0 ]] || {
    error "missing source URL"
    usage
    exit 1
  }

  SOURCE_URL="$1"
  shift

  if [[ "$MODE" == "replicate" ]]; then
    parse_replication_target "$@"
    return
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --local-root)
        require_arg "--local-root" "${2:-}"
        LOCAL_ROOT="$2"
        shift 2
        ;;
      --dest)
        require_arg "--dest" "${2:-}"
        DESTS+=("$2")
        shift 2
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      --debug)
        DEBUG=1
        shift
        ;;
      --verbose)
        VERBOSE=1
        shift
        ;;
      --auth-mode)
        require_arg "--auth-mode" "${2:-}"
        AUTH_MODE="$2"
        shift 2
        ;;
      --ssh-key-file)
        require_arg "--ssh-key-file" "${2:-}"
        SSH_KEY_FILE="$2"
        shift 2
        ;;
      --ssh-key-env)
        require_arg "--ssh-key-env" "${2:-}"
        SSH_KEY_ENV="$2"
        shift 2
        ;;
      --https-token)
        require_arg "--https-token" "${2:-}"
        HTTPS_TOKEN="$2"
        shift 2
        ;;
      --https-token-env)
        require_arg "--https-token-env" "${2:-}"
        HTTPS_TOKEN_ENV="$2"
        shift 2
        ;;
      *)
        error "unknown: $1"
        exit 2
        ;;
    esac
  done
}

function main() {
  parse_args "$@"
  init_logging "$DEBUG" "$VERBOSE" "$DRY_RUN"

  debug "Mode=$MODE"
  debug "Source=$SOURCE_URL"
  debug "Local root=$LOCAL_ROOT"
  if [[ -n "$TARGET_URL" ]]; then
    debug "Target=$TARGET_URL"
  fi

  export MIRROR_LOCAL_ROOT="$LOCAL_ROOT"

  setup_auth "$SOURCE_URL"
  trap auth_cleanup EXIT

  case "$MODE" in
    mirror)
      mirror_run "$SOURCE_URL"
      ;;
    sync)
      sync_run "$SOURCE_URL" "${DESTS[@]}"
      ;;
    replicate)
      replicate_run "$SOURCE_URL" "$TARGET_URL"
      ;;
  esac
}

main "$@"
